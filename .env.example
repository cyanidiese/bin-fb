# Trading mode: testnet | live
TRADING_MODE=testnet

# Testnet API credentials (https://testnet.binancefuture.com)
TESTNET_API_KEY=your_testnet_api_key_here
TESTNET_API_SECRET=your_testnet_api_secret_here

# Live API credentials (futures-only, no-withdrawal permissions)
API_KEY=your_live_api_key_here
API_SECRET=your_live_api_secret_here

# Required for live mode — set to "yes" only after reviewing all risk parameters
LIVE_MODE_CONFIRMED=no

# Trading symbol (e.g. BTCUSDT, ETHUSDT, XAUUSDT)
SYMBOL=BTCUSDT

# Kline interval (1m, 3m, 5m, 15m, 30m, 1h, 2h, 4h, 1d)
TIMEFRAME=15m

# How many historical klines to load and keep
KLINE_LIMIT=1000

# Number of candles required on each side to confirm a swing high/low
SWING_NEIGHBOURS=2

# Display timezone (IANA name, e.g. Europe/Kyiv, America/New_York, Asia/Tokyo)
TIMEZONE=UTC
