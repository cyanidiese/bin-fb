# Trading mode: testnet | live
TRADING_MODE=testnet

# Testnet API credentials (https://testnet.binancefuture.com)
TESTNET_API_KEY=your_testnet_api_key_here
TESTNET_API_SECRET=your_testnet_api_secret_here

# Live API credentials (futures-only, no-withdrawal permissions)
API_KEY=your_live_api_key_here
API_SECRET=your_live_api_secret_here

# Required for live mode — set to "yes" only after reviewing all risk parameters
LIVE_MODE_CONFIRMED=no

# Trading symbol (e.g. BTCUSDT, ETHUSDT, XAUUSDT)
SYMBOL=BTCUSDT

# Kline interval (1m, 3m, 5m, 15m, 30m, 1h, 2h, 4h, 1d)
TIMEFRAME=15m

# How many klines to fetch from the exchange per REST request
KLINE_LIMIT=1000

# Maximum candles to keep in the local cache file per symbol/timeframe/mode.
# Larger values give L2/L3 trends more history to build from.
KLINE_CACHE_LIMIT=5000

# Number of candles required on each side to confirm a swing high/low
SWING_NEIGHBOURS=2

# Display timezone (IANA name, e.g. Europe/Kyiv, America/New_York, Asia/Tokyo)
TIMEZONE=UTC

# ── Recommendation engine ─────────────────────────────────────────────────────

# Minimum active swing points (highs + lows) a trend level must have before
# generating a signal. Levels with fewer points are skipped.
MIN_SWING_POINTS=3

# Minimum expected profit as % of entry price. Signals with smaller TP distance
# are discarded before scoring.
MIN_PROFIT_PCT=0.5

# Minimum risk/reward ratio (profit distance / loss distance).
MIN_PROFIT_LOSS_RATIO=1.5

# Two scored candidates are treated as "similar precision" if their precision
# scores are within this threshold. Similar candidates then compete on R:R.
PRECISION_SIMILARITY_THRESHOLD=0.10

# How many recent swing highs and lows to include when computing projection
# reliability (coefficient of variation of amplitudes).
PROJECTION_LOOKBACK=4

# Entry-zone width as % of swing range from the nearest structural boundary.
# Price must be within this zone for the entry-quality score to be > 0.
# Also controls the closeness threshold in whichIsCloser().
PROXIMITY_ZONE_PCT=10.0

# Partial take: close the order early when price reaches this fraction of the
# TP distance from entry (0.0 = disabled). Acts as the activation threshold
# for the trailing stop below.
PARTIAL_TAKE_PCT=0.0

# Trailing stop: once the partial-take threshold is reached (armed), close the
# order if price retraces more than this fraction of the gained distance from entry.
# Example: 0.30 means "close if 30% of the move from entry to the peak is lost".
# Requires PARTIAL_TAKE_PCT > 0 to activate. 0.0 = disabled (uses fixed partial retrace).
TRAILING_STOP_PCT=0.0

# Conservative TP multiplier: scale projected TP distance by this factor before
# evaluating the trade. 0.90 = target 90% of full TP, easier to hit but smaller win.
# 1.0 = disabled (use full projected TP).
TP_MULTIPLIER=1.0

# SL distance filters (as % of entry price). Both default to 0.0 = disabled.
# MIN_SL_PCT: skip trades where SL is closer than this (avoids noise-level stops).
# MAX_SL_PCT: skip trades where SL is farther than this (limits max risk per trade).
MIN_SL_PCT=0.0
MAX_SL_PCT=0.0

# When true: tighten SL to meet MIN_PROFIT_LOSS_RATIO instead of skipping the trade.
# Useful when RR would otherwise discard too many valid setups.
SL_ADJUST_TO_RR=false

# Maximum allowed TP distance as % of entry price (0.0 = disabled).
# Trades where the projected TP is farther than this are skipped.
# Example: 3.0 means skip any trade with TP more than 3% away from entry.
MAX_PROFIT_PCT=0.0

# ── Candle-based directional cooldown ─────────────────────────────────────────

# After this many consecutive losses on one side (BUY or SELL), block that side
# for LOSS_STREAK_COOLDOWN_CANDLES candles. 0 = disabled.
# At 15m timeframe: 5 candles ≈ 75 min.
LOSS_STREAK_MAX=0
LOSS_STREAK_COOLDOWN_CANDLES=5

# If both BUY and SELL each suffered a loss within this many candles of each other,
# pause ALL new entries for GLOBAL_PAUSE_CANDLES candles (market likely ranging/choppy).
# 0 = disabled. Requires LOSS_STREAK_MAX > 0 to have effect.
GLOBAL_PAUSE_TRIGGER_CANDLES=0
GLOBAL_PAUSE_CANDLES=10
